{
  "name": "armario-social-server",
  "version": "1.0.0",
  "description": "Backend (API REST) do Armário Social — Express + Prisma + PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "prisma migrate deploy && node server.js",
    "build": "prisma generate",
    "dev": "node --watch server.js",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "armario-social",
    "express",
    "prisma",
    "postgresql"
  ],
  "author": "Grupo Armário Social — UNIFTEC",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  }
}
