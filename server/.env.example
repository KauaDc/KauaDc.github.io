# =========================================================
# Armário Social — variáveis de ambiente do backend
# Copie este arquivo para ".env" e ajuste os valores conforme
# a sua instalação local do PostgreSQL.
#   PowerShell:  Copy-Item .env.example .env
# =========================================================

# Porta em que o servidor web/API vai rodar
PORT=3000

# Conexão do Prisma com o PostgreSQL local.
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/armario_social?schema=public"

# Segredo usado para assinar os tokens de login (JWT).
# Troque por uma string longa e aleatória e mantenha em segredo.
JWT_SECRET="troque-isto-por-uma-string-aleatoria-longa"

# Conta de ADMINISTRADOR (super usuário), apenas no .env (não no banco).
ADMIN_USUARIO="admin"
ADMIN_SENHA="troque-esta-senha"
